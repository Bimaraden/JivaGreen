rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true ||
        request.auth.token.email == "hdhdg9089@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "hdhdg9089@gmail.com";
    }

    function isDbAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isAdmin() {
      return isSuperAdmin() || isDbAdmin();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'points', 'role', 'joinedAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.points is number && data.points >= 0 &&
             data.role in ['USER', 'ADMIN'] &&
             data.joinedAt is string;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isSuperAdmin() || userId == request.auth.uid);

      allow create: if isEmailVerified() && userId == request.auth.uid && 
                       isValidUser(incoming()) &&
                       incoming().id == request.auth.uid &&
                       incoming().role == 'USER' &&
                       incoming().points == 0;

      allow update: if isEmailVerified() && (
        (userId == request.auth.uid && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'ecoStats', 'joinedAt', 'bio', 'location', 'phone']) &&
          incoming().role == existing().role &&
          incoming().points == existing().points &&
          incoming().id == existing().id &&
          incoming().email == existing().email
        )) ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    function isValidWaste(data) {
      return data.keys().hasAll(['id', 'title', 'material', 'price', 'sellerId', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.material is string && data.material.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.sellerId is string && data.sellerId.size() <= 128 &&
             data.status in ['PENDING_APPROVAL', 'AVAILABLE', 'PENDING_PICKUP', 'PICKED_UP', 'RECYCLED', 'SOLD'] &&
             data.createdAt is string;
    }

    match /wastes/{wasteId} {
      allow list: if true; 
      allow get: if isValidId(wasteId);

      allow create: if isEmailVerified() && 
                       isValidWaste(incoming()) && 
                       incoming().sellerId == request.auth.uid &&
                       incoming().status == 'PENDING_APPROVAL';

      allow update: if isEmailVerified() && (
        (existing().sellerId == request.auth.uid && incoming().sellerId == existing().sellerId && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'material', 'price', 'description', 'condition', 'imageUrl', 'latitude', 'longitude', 'address', 'composition']) &&
           existing().status in ['PENDING_APPROVAL', 'AVAILABLE']) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'soldAt']) && incoming().status == 'SOLD' && existing().status == 'AVAILABLE')
        )) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'buyerId', 'pickedUpAt']) && 
         existing().status == 'AVAILABLE' && 
         incoming().status == 'PENDING_PICKUP' &&
         incoming().buyerId == request.auth.uid &&
         incoming().sellerId == existing().sellerId) ||
        isAdmin()
      );

      allow delete: if isAdmin() || (isEmailVerified() && existing().sellerId == request.auth.uid && existing().status == 'PENDING_APPROVAL');
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['id', 'userId', 'points', 'amount', 'method', 'accountNumber', 'status', 'date']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.points is number && data.points > 0 &&
             data.amount is number && data.amount > 0 &&
             data.method is string && data.accountNumber is string &&
             data.status in ['PENDING', 'COMPLETED', 'REJECTED'] &&
             data.date is string;
    }

    match /withdrawal_requests/{requestId} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && isValidId(requestId) && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isEmailVerified() && 
                       isValidWithdrawal(incoming()) && 
                       incoming().userId == request.auth.uid &&
                       incoming().status == 'PENDING';

      allow update: if isAdmin() && 
                       isValidWithdrawal(incoming()) &&
                       existing().status == 'PENDING' &&
                       incoming().userId == existing().userId &&
                       incoming().points == existing().points; 

      allow delete: if isAdmin();
    }
  }
}
